<?xml version='1.0' encoding='utf-8'?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>
        <!-- Conexión a SQLite -->
        <property name="hibernate.connection.driver_class">org.sqlite.JDBC</property>
        <property name="hibernate.connection.url">jdbc:sqlite:cdf_database.db</property>
        <property name="hibernate.connection.username"></property>
        <property name="hibernate.connection.password"></property>

        <!-- Dialecto para SQLite (Hibernate 6+) -->
        <property name="hibernate.dialect">org.hibernate.community.dialect.SQLiteDialect</property>

        <!-- Mostrar y formatear el SQL en consola -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Actualizar el esquema de la base de datos automáticamente (crea las tablas si no existen) -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Mapeo de entidades (Aquí agregaremos nuestras clases entidad) -->
        <mapping class="org.example.entidades.Producto"/>
        <mapping class="org.example.entidades.Proveedor"/>
        <!-- <mapping class="org.example.entity.Usuario"/> -->
    </session-factory>
</hibernate-configuration>